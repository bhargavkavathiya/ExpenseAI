# UC10 — production environment for the portal deploy.
# The pipeline renames this file to `.env` before building.
# NEVER put real secrets here — this file is committed to git.
# The portal injects runtime secrets (OPENAI key, JWT secret) via its own vault.

# ---------- Postgres ----------
POSTGRES_USER=uc10
POSTGRES_PASSWORD=uc10_changeme
POSTGRES_DB=uc10

# ---------- Backend (.NET 8) ----------
# ASPNETCORE_URLS and ConnectionStrings__Default are hard-wired inside
# docker-compose.prod.yml so the backend always resolves postgres by its
# compose service name.
Jwt__Issuer=uc10-api
Jwt__Audience=uc10-clients
Jwt__AccessTokenTtlMinutes=720

# Dev-only placeholder — replace via portal secrets before real traffic.
# HS256 requires >= 256 bits (32 bytes) of entropy.
Jwt__Secret=replace-me-with-a-64-char-random-string-injected-by-portal-vault-ok

# Leave blank = AI services run in deterministic stub mode (the demo still
# works end-to-end). The portal vault injects the real key when available.
OpenAI__ApiKey=
OpenAI__Model=gpt-4o
OpenAI__TimeoutMs=5000

# GSTIN lookup — leaving key blank falls back to deterministic demo mode.
Gstin__ApiKey=
Gstin__ApiBase=https://sheet.gstincheck.co.in
Gstin__TimeoutMs=5000

# Behind the same-origin nginx proxy, CORS is effectively unused, but we keep
# a permissive default so Swagger UI works when hit directly.
Cors__AllowedOrigins=*
Serilog__MinimumLevel=Information

Storage__UploadsPath=/app/uploads
Storage__MaxBytes=10485760
