# Copy to .env and fill values. .env is gitignored.

# ---------- PostgreSQL ----------
POSTGRES_USER=uc10
POSTGRES_PASSWORD=uc10_changeme
POSTGRES_DB=uc10
POSTGRES_PORT=5432

# ---------- Backend (.NET 8 Web API) ----------
# ConnectionStrings__Default is read by ASP.NET Core. Host is the compose service name inside the network.
ConnectionStrings__Default=Host=postgres;Port=5432;Database=uc10;Username=uc10;Password=uc10_changeme;Include Error Detail=true
Jwt__Secret=replace-with-at-least-64-chars-of-random-bytes-for-hs256-signing-ok
Jwt__Issuer=uc10-api
Jwt__Audience=uc10-clients
Jwt__AccessTokenTtlMinutes=720

# Leave OpenAI__ApiKey blank to use deterministic stub AI services (demo still works end-to-end).
OpenAI__ApiKey=
OpenAI__Model=gpt-4o
OpenAI__TimeoutMs=5000

Gstin__ApiKey=
Gstin__ApiBase=https://api.example-gst.in
Gstin__TimeoutMs=3000

Cors__AllowedOrigins=http://localhost:4200,http://localhost:19006,http://localhost:5173
Serilog__MinimumLevel=Information

Storage__UploadsPath=/app/uploads
Storage__MaxBytes=10485760

# ---------- Frontend (Angular build-time) ----------
NG_APP_API_BASE=http://localhost:8080/api

# ---------- Mobile (Expo) ----------
EXPO_PUBLIC_API_BASE=http://localhost:8080/api
