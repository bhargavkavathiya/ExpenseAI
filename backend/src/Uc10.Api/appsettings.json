{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Default": "Host=localhost;Port=5432;Database=uc10;Username=postgres;Password=Admin@123;Include Error Detail=true"
  },
  "Jwt": {
    "Secret": "replace-with-at-least-64-chars-of-random-bytes-for-hs256-signing-ok-dev",
    "Issuer": "uc10-api",
    "Audience": "uc10-clients",
    "AccessTokenTtlMinutes": 720
  },
  "OpenAI": { "Model": "gpt-4o", "TimeoutMs": 30000 },
  "Gstin":  { "ApiBase": "https://api.example-gst.in", "TimeoutMs": 3000 },
  "Cors": { "AllowedOrigins": "http://localhost:4200,http://localhost:19006,http://localhost:5173,http://localhost:58089" },
  "Storage":{ "UploadsPath": "/app/uploads", "MaxBytes": 10485760 }
}
